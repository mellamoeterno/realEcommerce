generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model product_types {
  id        String     @id @db.Char(36)
  type_name String     @unique(map: "type_name") @db.VarChar(100)
  products  products[]
}

model products {
  id              String           @id @db.Char(36)
  price           Decimal          @db.Decimal(10, 2)
  quantity_limit  Int
  product_type_id String           @db.Char(36)
  created_at      DateTime?        @default(now()) @db.Timestamp(0)
  name            String           @db.VarChar(255)
  product_images  product_images[]
  product_types   product_types    @relation(fields: [product_type_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "products_ibfk_1")

  @@index([product_type_id], map: "product_type_id")
}

model product_images {
  id         Int      @id @default(autoincrement())
  product_id String   @db.Char(36)
  image_url  String   @db.VarChar(255)
  is_primary Boolean? @default(false)
  products   products @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "product_images_ibfk_1")

  @@index([product_id], map: "product_id")
}
